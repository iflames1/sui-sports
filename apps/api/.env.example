# Copy to `.env` in this directory for local API runs:
#   cp .env.example .env
# Host ports match docker-compose.yml (Postgres 5433, Redis 6380).
#
# Deploying to Railway:
#   - Add a Postgres plugin — DATABASE_URL is injected automatically.
#   - (Optional) Add a Redis plugin — REDIS_URL is injected automatically.
#   - Set JWT_SECRET and CORS_ORIGINS (e.g. https://your-app.vercel.app).
#   - Railway sets PORT; the binary binds 0.0.0.0:$PORT automatically.
#   - For on-chain verification set SUI_TX_VERIFY_RELAXED=false in production.

DATABASE_URL=postgres://suisports:suisports@127.0.0.1:5433/suisports
JWT_SECRET=change-me-in-production
CORS_ORIGINS=http://localhost:3000
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_TX_VERIFY_RELAXED=true
BIND_ADDR=0.0.0.0:8080

# REDIS_URL=redis://127.0.0.1:6380
# BOOTSTRAP_ADMIN_ZKLOGIN_SUBJECT=wallet:0xYOUR_ADDRESS
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# LIVEKIT_URL=wss://your-livekit-host
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com
